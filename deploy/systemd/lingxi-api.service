[Unit]
Description=LingXi FastAPI
After=network.target postgresql.service redis-server.service

[Service]
User=lingxi
WorkingDirectory=/opt/lingxi/apps/api
EnvironmentFile=/opt/lingxi/apps/api/.env
ExecStart=/opt/lingxi/apps/api/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
