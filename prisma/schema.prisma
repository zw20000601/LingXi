generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipStatus {
  FREE
  PRO
}

enum JobType {
  VIDEO_PARSE
  VIDEO_TRANSCRIBE
  COPY_REWRITE
  CONVERT
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

model User {
  id                String           @id @default(uuid())
  email             String           @unique
  password_hash     String
  membership_status MembershipStatus @default(FREE)
  is_disabled       Boolean          @default(false)
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  jobs              Job[]
  files             FileAsset[]

  @@map("users")
}

model Job {
  id              String     @id @default(uuid())
  type            JobType
  status          JobStatus  @default(PENDING)
  input           Json?
  result          Json?
  error           String?
  user_id         String
  user            User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  input_file_id   String?
  input_file      FileAsset? @relation("InputFile", fields: [input_file_id], references: [id])
  output_file_id  String?
  output_file     FileAsset? @relation("OutputFile", fields: [output_file_id], references: [id])
  expires_at      DateTime
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  @@index([user_id, created_at])
  @@index([status])
  @@index([expires_at])
  @@map("jobs")
}

model FileAsset {
  id            String   @id @default(uuid())
  original_name String
  storage_path  String
  mime_type     String?
  size_bytes    Int
  user_id       String
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at    DateTime
  created_at    DateTime @default(now())
  input_jobs    Job[]    @relation("InputFile")
  output_jobs   Job[]    @relation("OutputFile")

  @@index([user_id, created_at])
  @@index([expires_at])
  @@map("file_assets")
}

model AppSetting {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("app_settings")
}

model CardKey {
  id         String   @id @default(uuid())
  code       String   @unique
  type       String
  quota      Int
  valid_days Int
  status     String   @default("UNUSED")
  used_by    String?
  used_at    DateTime?
  expires_at DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status])
  @@index([expires_at])
  @@map("card_keys")
}

model Announcement {
  id         String   @id @default(uuid())
  title      String
  type       String
  status     String   @default("DRAFT")
  content    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status])
  @@map("announcements")
}
